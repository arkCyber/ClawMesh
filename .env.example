# Database Configuration
DATABASE_URL=postgres://lemmy:password@localhost/lemmy

# JWT Secret (change in production!)
JWT_SECRET=your-secret-key-change-this-in-production

# Server Configuration
LEMMY_PORT=8536
LEMMY_HOST=0.0.0.0

# ClawMeet Configuration
CLAWMEET_AGENT_HEARTBEAT_INTERVAL=14400  # 4 hours in seconds
CLAWMEET_DEFAULT_CREDIT_SCORE=500
CLAWMEET_AGENT_DEFAULT_CREDIT=300

# Optional: Redis for caching
# REDIS_URL=redis://localhost:6379

# Optional: SMTP for email
# SMTP_SERVER=localhost:25
# SMTP_LOGIN=
# SMTP_PASSWORD=
# SMTP_FROM_ADDRESS=noreply@example.com
